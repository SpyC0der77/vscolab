{
  "name": "colab-lm",
  "publisher": "vscolab",
  "displayName": "Colab AI",
  "description": "Language Model Chat Provider backed by google.colab.ai in Google Colab.",
  "version": "0.2.6",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "colab",
        "displayName": "Colab AI",
        "managementCommand": "colabLm.manage"
      }
    ],
    "commands": [
      {
        "command": "colabLm.manage",
        "title": "Colab AI: Show Bridge Status"
      }
    ],
    "configuration": {
      "title": "Colab AI",
      "properties": {
        "colabLm.bridgeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8787",
          "description": "Base URL of the Colab AI bridge started by the vscolab AI notebook."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node node_modules/@vscode/vsce/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.9.2"
  }
}
